// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "windows"]
  output        = "../release/app/node_modules/@prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

model User {
  id         String   @id @default(uuid())
  name       String   @unique
  password   String?
  lockapp    Boolean  @default(false)
  createdAt  DateTime @default(now())
  default    Boolean  @default(false)
  location   Location @relation(fields: [locationId], references: [id])
  locationId String
}

model Location {
  id        String  @id @default(uuid())
  name      String  @unique
  tel       String
  fromColis Colis[] @relation("from")
  toColis   Colis[] @relation("to")
  User      User[]
}

model Colis {
  id             Int       @id @default(autoincrement())
  name           String?
  quantity       Int
  date           DateTime
  car            String
  from           Location? @relation("from", fields: [fromLocationId], references: [id])
  to             Location? @relation("to", fields: [toLocationId], references: [id])
  expName        String?
  expPhone       String?
  recName        String?
  recPhone       String
  paid           Boolean   @default(false)
  fees           Float
  fromLocationId String
  toLocationId   String
}
